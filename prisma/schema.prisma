generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Admins{
    id String @id @default(auto()) @map("_id") @db.ObjectId

  
  username String @unique
  email String @unique 
 
  password String

  last_loggedIn DateTime @default(now())
  created_at DateTime @default(now())
 
}
model Locations{
    id String @id @default(auto()) @map("_id") @db.ObjectId

  
  name String 
  description String? 
  category String
  lat Float?  
  long Float?
 
  aliases String[] @default([])
  num_of_search Int @default(0)
  created_at DateTime @default(now())
  
}
model SuggestedLocations{
    id String @id @default(auto()) @map("_id") @db.ObjectId

  
  name String 
  description String? 
  category String
  lat Float?  
  long Float?
 
  aliases String?
  num_of_search Int @default(0)
  created_at DateTime @default(now())
  
}